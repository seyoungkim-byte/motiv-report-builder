<!doctype html>
<html lang="ko">
<head>
<meta charset="utf-8">
<title>{{ headline }}</title>
<style>{{ css | safe }}</style>
</head>
<body>
<section class="page">

  {# ── 헤더 띠 (Securities Note 톤) ───────────────────────── #}
  <header class="hdr">
    <span class="hdr__brand">{{ company.name }}</span>
    <span class="hdr__divider">▌</span>
    <span class="hdr__type">Case Study Note</span>
    <span class="hdr__meta">
      {% if campaign.campaign_no %}No. {{ campaign.campaign_no }} · {% endif %}
      {% if campaign.period_start %}{{ campaign.period_start }}{% if campaign.period_end %} – {{ campaign.period_end }}{% endif %}{% endif %}
    </span>
  </header>

  {# ── 타이틀 + TL;DR ───────────────────────────────────── #}
  <section class="title-block">
    <h1 class="title-block__h1">{{ headline }}</h1>
    {% if subhead %}<p class="title-block__sub">{{ subhead }}</p>{% endif %}

    {# ── 캠페인 운영 개요 (헤더 메타 행 + 태그 칩) ── #}
    {% set hm = header_meta or {} %}
    {% if hm %}
    <div class="hdr-meta">
      <div class="hdr-meta__row">
        {% if hm.advertiser %}
        <span class="hdr-meta__item">
          <span class="hdr-meta__dot"></span>
          <span class="hdr-meta__label">광고주</span>
          <span class="hdr-meta__value">{{ hm.advertiser }}</span>
        </span>
        {% endif %}
        {% if hm.period_start %}
        <span class="hdr-meta__item">
          <span class="hdr-meta__dot"></span>
          <span class="hdr-meta__label">집행 기간</span>
          <span class="hdr-meta__value">
            {{ hm.period_start }}{% if hm.period_end %} ~ {{ hm.period_end }}{% endif %}
            {% if hm.cumulative_period %} · {{ hm.cumulative_period }}{% endif %}
          </span>
        </span>
        {% endif %}
        {% if hm.media_products %}
        <span class="hdr-meta__item">
          <span class="hdr-meta__dot"></span>
          <span class="hdr-meta__label">집행 상품</span>
          <span class="hdr-meta__value">{{ hm.media_products }}</span>
        </span>
        {% endif %}
        {% if hm.measurement_source %}
        <span class="hdr-meta__item">
          <span class="hdr-meta__dot"></span>
          <span class="hdr-meta__label">구매 측정</span>
          <span class="hdr-meta__value">{{ hm.measurement_source }}</span>
        </span>
        {% endif %}
      </div>
      {% if hm.tags %}
      <div class="hdr-meta__tags">
        {% for tag in hm.tags %}<span class="hdr-meta__chip">{{ tag }}</span>{% endfor %}
      </div>
      {% endif %}
    </div>
    {% endif %}

    {% if narrative.tldr %}
    <ul class="tldr">
      {% for item in narrative.tldr %}
      <li>{{ item }}</li>
      {% endfor %}
    </ul>
    {% endif %}
  </section>

  {# ── KPI 스트립 ────────────────────────────────────────── #}
  {% if campaign.metrics_table %}
  <section class="kpis">
    {% for m in campaign.metrics_table[:4] %}
    <div class="kpi">
      <span class="kpi__label">{{ m.indicator }}</span>
      <span class="kpi__value">{{ m.value }}</span>
      {% if m.note %}<span class="kpi__note">{{ m.note }}</span>{% endif %}
    </div>
    {% endfor %}
  </section>
  {% endif %}

  {# ── 본문 — 1단 세로 흐름 ─────────────────────────────── #}
  <section class="body">

    {% if narrative.summary %}
    <div class="summary">
      <h3>요약</h3>
      <p>{{ narrative.summary }}</p>
    </div>
    {% endif %}

    {# 본문 섹션 매크로 — list 면 불릿, str 면 단락 #}
    {% macro section(num, title, items) %}
      <h2><span class="sec-num">{{ num }}</span>{{ title }}</h2>
      {% if items is string %}
        <p>{{ items }}</p>
      {% elif items %}
        <ul class="body-bullets">
          {% for it in items %}<li>{{ it }}</li>{% endfor %}
        </ul>
      {% endif %}
    {% endmacro %}

    {# ── 2단 — 좌측 본문 / 우측 04 성과 지표 표 ── #}
    <div class="body-grid">
      <div class="body-grid__main">
        {{ section('01', '캠페인 개요',           narrative.overview)   }}
        {{ section('02', '광고 집행 배경',         narrative.background) }}
        {{ section('03', '적용 전략 · 핵심 성과',  narrative.strategy)   }}
      </div>

      {% if campaign.metrics_table %}
      <aside class="body-grid__side">
        <h2><span class="sec-num">04</span>캠페인 성과</h2>
        <table class="metrics metrics--side">
          <thead>
            <tr><th>성과 지표</th><th>성과</th><th>비고</th></tr>
          </thead>
          <tbody>
            {% for m in campaign.metrics_table %}
            <tr>
              <td class="metrics__indicator">{{ m.indicator }}</td>
              <td class="metrics__value">{{ m.value }}</td>
              <td class="metrics__note">{{ m.note }}</td>
            </tr>
            {% endfor %}
          </tbody>
        </table>
      </aside>
      {% endif %}
    </div>

    {# ── 핵심 인사이트 callout (풀폭) — 차트 위에 배치 ── #}
    {% if narrative.insights %}
    <div class="insights-box">
      <h3>핵심 인사이트</h3>
      <ul>
        {% for item in narrative.insights %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {# ── 차트 (그림 N) — 인사이트 BELOW. 풀폭. ── #}
    {% set all_charts = (charts.performance or []) + ([charts.inline_strategy] if charts.inline_strategy else []) %}
    {% if all_charts %}
    <div class="figs figs--{{ all_charts|length }}">
      {% for ch in all_charts %}
      <figure class="fig">
        <div class="fig__head">
          <span class="fig__num">[그림 {{ loop.index }}]</span>
          <span class="fig__title">{{ ch.title }}</span>
        </div>
        <img src="data:image/png;base64,{{ ch.image_b64 }}" alt="{{ ch.title }}">
        {% if ch.caption %}<figcaption>{{ ch.caption }}</figcaption>{% endif %}
      </figure>
      {% endfor %}
    </div>
    {% endif %}
  </section>

  {# ── About + Footer 띠 ──────────────────────────────── #}
  <footer class="ftr">
    <div class="ftr__about">
      <strong>About {{ company.name }}</strong>
      <span>{{ company.description }}</span>
    </div>
    <div class="ftr__meta">
      <span>{{ company.url }}{% if company.url_secondary %} · {{ company.url_secondary }}{% endif %}</span>
      <span>{{ company.press_contact_email }}</span>
      <span>© {{ year }} {{ company.name }} Inc.</span>
    </div>
  </footer>

</section>
</body>
</html>
