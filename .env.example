# Shared Supabase DB (same project as casestudy_dashboard)
SUPABASE_URL=https://crnuzttgawbkqqxzrmzr.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# Anthropic API (narrative generation — Sonnet 4.6)
ANTHROPIC_API_KEY=your-anthropic-key
ANTHROPIC_TEXT_MODEL=claude-sonnet-4-6

# Gemini API (hero image generation — manual upload is the alternative)
# 주의: imagen-* 모델은 generate_content 엔드포인트 미지원. 이미지 출력 가능
# Gemini 멀티모달 모델을 사용해야 함 (예: gemini-2.5-flash-image-preview).
GEMINI_API_KEY=your-gemini-key
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image-preview

# Output directory
OUTPUT_DIR=./output

# Auth — Google SSO via Supabase, restricted to ALLOWED_DOMAIN
# Locally: http://localhost:8501. On Streamlit Cloud: the deployed URL.
APP_URL=http://localhost:8501
ALLOWED_DOMAIN=motiv-i.com

# Company / footer metadata (matches the reference PDF)
COMPANY_NAME=Motiv Intelligence
COMPANY_URL=https://www.motiv-i.com
COMPANY_URL_SECONDARY=https://www.crosstarget.co.kr
COMPANY_LOGO_URL=
COMPANY_DESCRIPTION=모티브인텔리전스는 CTV 광고와 크로스디바이스 타겟팅 기술을 기반으로, CTV·모바일 광고 집행부터 전환 및 구매 성과 분석까지 지원하는 애드테크 기업입니다.
PRESS_CONTACT_NAME=
PRESS_CONTACT_EMAIL=crosstarget@motiv-i.com
